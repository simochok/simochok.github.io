{
  "pipeline_name": "Canva Agency Pack Automation",
  "target_product": "packs_canva_pour_petites_entreprises_1_agences",
  "run_frequency": "one_off",
  "error_handling": "stop_and_notify",
  "execution_order": [
    "generate_master_links",
    "generate_guide_pdf",
    "generate_license_pdf",
    "generate_bonus_scripts",
    "package_zip"
  ],
  "modules": [
    {
      "step_id": "generate_master_links",
      "agent": "link_generator_agent",
      "input_params": {
        "template_count": 50,
        "platforms": [
          "Instagram",
          "LinkedIn",
          "Facebook"
        ],
        "style": "neutral_business"
      },
      "system_prompt": "Tu es un expert Canva. Génère une liste structurée de liens vers des templates Canva.",
      "output_format": "json",
      "validation_rule": "count >= 50"
    },
    {
      "step_id": "generate_guide_pdf",
      "agent": "pdf_creator_agent",
      "input_params": {
        "title": "Guide d'Adaptation Rapide"
      },
      "system_prompt": "Crée le contenu d'un guide PDF expliquant comment utiliser la fonction Brand Kit de Canva.",
      "output_format": "markdown",
      "validation_rule": "contains Brand Kit"
    },
    {
      "step_id": "generate_license_pdf",
      "agent": "legal_drafter_agent",
      "input_params": {
        "license_type": "Commercial Extended"
      },
      "system_prompt": "Rédige une licence commerciale simple et claire.",
      "output_format": "markdown",
      "validation_rule": "contains No resale"
    },
    {
      "step_id": "generate_bonus_scripts",
      "agent": "copywriter_agent",
      "input_params": {
        "focus": "Upsell to existing clients"
      },
      "system_prompt": "Rédige 3 scripts d'emails pour proposer ce service.",
      "output_format": "markdown",
      "validation_rule": "count_emails == 3"
    },
    {
      "step_id": "package_zip",
      "agent": "archiver_agent",
      "input_params": {
        "files_from_steps": [
          "generate_master_links",
          "generate_guide_pdf",
          "generate_license_pdf",
          "generate_bonus_scripts"
        ],
        "archive_name": "Agency_Canva_System.zip"
      },
      "system_prompt": "Prends tous les fichiers générés et zippe le tout.",
      "output_format": "file_path",
      "validation_rule": "file_exists"
    }
  ]
}